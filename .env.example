# .env.example — copy to .env and fill in your credentials

# --- Choose your AI provider ---
# Options: github | openai | gemini
PROVIDER=github

# --- GitHub Models (free tier, requires GitHub PAT) ---
# Get a PAT at: https://github.com/settings/tokens
# No special scopes required.
GITHUB_TOKEN=ghp_your_token_here

# --- OpenAI (pay-per-use) ---
# Get an API key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# --- Google Gemini (free tier via AI Studio) ---
# Get a free API key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...

# --- Optional defaults ---
# DEFAULT_MODEL=gpt-4o-mini
# DEFAULT_TONE=formal

# --- Token usage controls ---
# DEBOUNCE_DELAY=1.2       # Seconds of inactivity before triggering generation
# MIN_INPUT_CHARS=15       # Skip generation for inputs shorter than this
# MAX_INPUT_CHARS=2000     # Truncate inputs longer than this before sending to API
